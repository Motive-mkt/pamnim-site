{
  "entities": {
    "Profile": {
      "title": "User Profile",
      "description": "Stores user roles and basic information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "senior_designer", "designer", "project_manager", "client"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Project": {
      "title": "Client Project",
      "description": "Represents an interior design project.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "clientId": { "type": "string" },
        "employeeIds": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "completed", "on-hold"] },
        "phases": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "status": { "type": "string", "enum": ["pending", "active", "complete"] },
              "description": { "type": "string" },
              "date": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "clientId"]
    },
    "ProgressNote": {
      "title": "Progress Note",
      "description": "Updates shared between team and client.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "authorId"]
    },
    "SiteContent": {
      "title": "Site Content",
      "description": "CMS data for the homepage.",
      "type": "object",
      "properties": {
        "hero": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "subheadline": { "type": "string" },
            "highlightWord": { "type": "string" }
          }
        },
        "contact": {
          "type": "object",
          "properties": {
            "phone": { "type": "string" },
            "whatsapp": { "type": "string" },
            "email": { "type": "string" },
            "address": { "type": "string" }
          }
        },
        "services": { "type": "array" },
        "portfolio": { "type": "array" }
      }
    },
    "MediaItem": {
      "title": "Media Item",
      "description": "An image item for the gallery or portfolio.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "image"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "A customer message from the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "projectType": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "read", "responded"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message"]
    }
  },
  "firestore": {
    "profiles": {
      "schema": "Profile",
      "description": "User profile records."
    },
    "projects": {
      "schema": "Project",
      "description": "Interior design projects."
    },
    "projects/{projectId}/progressNotes": {
      "schema": "ProgressNote",
      "description": "Chronological updates for a project."
    },
    "siteContent": {
      "schema": "SiteContent",
      "description": "CMS configurations."
    },
    "gallery": {
      "schema": "MediaItem",
      "description": "Home page gallery images."
    },
    "portfolio": {
      "schema": "MediaItem",
      "description": "Full portfolio collection."
    },
    "inquiries": {
      "schema": "Inquiry",
      "description": "Customer contact form submissions."
    }
  }
}
