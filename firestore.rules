rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isVerified() { 
      return isSignedIn() && (
        request.auth.token.get('email_verified', false) == true || 
        request.auth.token.get('firebase', {}).get('sign_in_provider', '') == 'password'
      ); 
    }
    
    function getProfile(uid) {
      return get(/databases/$(database)/documents/profiles/$(uid)).data;
    }
    
    function hasRole(role) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
             getProfile(request.auth.uid).get('role', '') == role;
    }
    
    function isOwner() { 
      return isSignedIn() && (
        ('email' in request.auth.token && (
          request.auth.token.email == 'jessescaledyou@gmail.com' || 
          request.auth.token.email == 'your-admin-email@example.com' ||
          request.auth.token.email.matches('(?i)^jessescaledyou@gmail[.]com$') || 
          request.auth.token.email.matches('(?i)^your-admin-email@example[.]com$')
        )) ||
        (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && (
          getProfile(request.auth.uid).get('role', '') == 'owner' ||
          getProfile(request.auth.uid).get('email', '') == 'jessescaledyou@gmail.com' ||
          getProfile(request.auth.uid).get('email', '') == 'your-admin-email@example.com'
        ))
      );
    }
    function isEmployee() {
      return isSignedIn() && exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
             (getProfile(request.auth.uid).get('role', '') == 'senior_designer' || 
              getProfile(request.auth.uid).get('role', '') == 'designer' || 
              getProfile(request.auth.uid).get('role', '') == 'project_manager');
    }
    function isClient() { return hasRole('client'); }

    // Validation Helpers
    function isValidMediaItem(data) {
      return data.keys().hasAll(['title', 'category', 'image', 'createdAt']) &&
             data.title is string &&
             data.category is string &&
             data.image is string &&
             data.createdAt is string;
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'status', 'createdAt']) &&
             data.name is string && data.name.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.message is string && data.message.size() <= 5000 &&
             data.status in ['new', 'read', 'responded'] &&
             data.createdAt is string && data.createdAt.size() <= 100;
    }

    // Profiles
    match /profiles/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Protected updates: users can't change their own role, unless they are a hardcoded admin
      allow update: if isOwner() || 
                    (request.auth.uid == userId && (
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) ||
                      resource.data.get('email', '') == 'jessescaledyou@gmail.com' ||
                      resource.data.get('email', '') == 'your-admin-email@example.com' ||
                      ('email' in request.auth.token && (
                        request.auth.token.email == 'jessescaledyou@gmail.com' ||
                        request.auth.token.email == 'your-admin-email@example.com' ||
                        request.auth.token.email.matches('(?i)^jessescaledyou@gmail[.]com$') || 
                        request.auth.token.email.matches('(?i)^your-admin-email@example[.]com$')
                      ))
                    ));
    }

    // Projects
    match /projects/{projectId} {
      allow read: if isOwner() || isEmployee() || (isClient() && resource.data.clientId == request.auth.uid);
      allow create: if isOwner();
      allow update: if isOwner() || (isEmployee() && (request.auth.uid in resource.data.employeeIds));
      allow delete: if isOwner();
      
      match /progressNotes/{noteId} {
        allow read: if isOwner() || isEmployee() || (isClient() && get(/databases/$(database)/documents/projects/$(projectId)).data.clientId == request.auth.uid);
        allow create: if isOwner() || isEmployee();
        allow update, delete: if isOwner();
      }
    }

    // Site Content
    match /siteContent/{docId} {
      allow read: if true;
      allow write: if isOwner() || (docId == 'metadata' && !exists(/databases/$(database)/documents/siteContent/metadata));
    }

    // Media Collections (Gallery & Portfolio)
    match /gallery/{itemId} {
      allow read: if true;
      allow create, update: if isOwner() && isValidMediaItem(request.resource.data);
      allow delete: if isOwner();
    }

    match /portfolio_assets/{itemId} {
      allow read: if true;
      allow create, update: if isOwner() && isValidMediaItem(request.resource.data);
      allow delete: if isOwner();
    }

    // Inquiries
    match /inquiries/{inquiryId} {
      allow create: if isValidInquiry(request.resource.data);
      allow read, update, delete: if isOwner();
    }
    
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
